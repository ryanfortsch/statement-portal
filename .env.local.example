NEXT_PUBLIC_SUPABASE_URL=https://your-helm-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_helm_anon_key_here
NEXT_PUBLIC_PORTAL_TOKEN=your_secret_token_here

# Auth.js / Google SSO
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=

# Stay Concierge (guest messaging service, powers /messaging)
# URL is the public Cloudflare Tunnel hostname for the FastAPI service on the
# Mac Mini; KEY is the same DASHBOARD_KEY env var the service uses to gate
# /dashboard. Both server-side only - never expose to the client.
STAY_CONCIERGE_URL=https://conciergestaycollections.com
STAY_CONCIERGE_KEY=

# Seam (smart-lock API; powers the lock-battery turnover alert + auto-slips)
# SEAM_API_KEY: Seam dashboard > Developer > API Keys.
# SEAM_WEBHOOK_SECRET: the Svix signing secret shown when you create the
# webhook in Seam (starts with "whsec_"). Both server-side only.
SEAM_API_KEY=
SEAM_WEBHOOK_SECRET=

# GitHub (powers the Stay Cape Ann launch flow at /properties/[id]/stay-cape-ann)
# GITHUB_TOKEN: a FINE-GRAINED personal access token scoped to ONLY the
# ryanfortsch/stay-cape-ann repository, with Repository permissions
# Contents: Read and write + Pull requests: Read and write. Nothing else.
# This is the only standing cross-repo credential Helm holds. Server-side only;
# never exposed to the client, never logged, never stored in the database.
GITHUB_TOKEN=
# SCA_ADMIN_TOKEN (optional): the stay-cape-ann ADMIN_TOKEN, used only to
# trigger a Guesty snapshot refresh after a launch. Leave blank to skip; the
# site still renders new listings from a build-time Guesty pull.
SCA_ADMIN_TOKEN=
